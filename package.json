{
  "name": "@eggjs/create",
  "version": "0.0.2",
  "description": "eggjs create template",
  "keywords": [
    "create",
    "eggjs",
    "template"
  ],
  "homepage": "https://github.com/eggjs/create",
  "bugs": {
    "url": "https://github.com/eggjs/create/issues"
  },
  "license": "MIT",
  "author": "eggjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eggjs/create.git"
  },
  "files": [
    "templates"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "vp config"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "vite-plus": "catalog:"
  },
  "packageManager": "pnpm@10.33.2",
  "createConfig": {
    "templates": [
      {
        "name": "monorepo",
        "description": "Monorepo",
        "template": "./templates/monorepo",
        "monorepo": true
      },
      {
        "name": "app",
        "description": "Egg app template",
        "template": "./templates/app"
      },
      {
        "name": "plugin",
        "description": "Egg plugin template",
        "keywords": [
          "plugin"
        ],
        "template": "./templates/plugin"
      }
    ]
  }
}
